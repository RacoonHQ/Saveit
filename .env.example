# =================================================================
# ⚙️ SAVEIT - CONFIGURATION TEMPLATE
# Rename this file to `.env` and fill in the values below.
# =================================================================

# -----------------------------------------------------------------
# 👤 USERBOT MODE (Saveit.py)
# -----------------------------------------------------------------
# Get your API ID and API HASH from https://my.telegram.org
# You can add multiple accounts by incrementing the suffix (_1, _2, etc.)

API_ID_1=123456
API_HASH_1=abcdef1234567890abcdef1234567890

# Optional: Account 2
# API_ID_2=789012
# API_HASH_2=fedcba0987654321fedcba0987654321

# Command prefix for userbot manual mode.
# - If set (e.g., '.saveit'), you must reply to a media message with '.saveit' to save it.
# - If left empty, automatic saving is enabled (reply to any media to save it without commands).
HANDLER=.saveit

# -----------------------------------------------------------------
# 🤖 BOT MODE (Saveit_bot.py)
# -----------------------------------------------------------------
# Create a bot via @BotFather to get this token
BOT_TOKEN=8612562447:AAEGsXdgOoW6Vaow4APqUbXujhJUBV9h60o

# Comma-separated list of Telegram User IDs allowed to use the bot.
# If left empty, all users will be allowed.
ALLOWED_USERS=123456789,987654321

# Auto-save mode for Bot:
# - true: automatically saves and returns any media sent directly to the bot.
# - false: only saves media when you reply to it with the handler command.
AUTO_SAVE=true